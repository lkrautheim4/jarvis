# GET https://api.binance.com/api/v3/ticker/price?symbol=BTCUSDT

### CoinGecko market_chart — CORS blocked without paid key
# GET https://api.coingecko.com/api/v3/coins/bitcoin/market_chart?vs_currency=usd&days=1

###############################################
# KRAKEN RESPONSE FORMAT NOTES
###############################################
# Ticker response: result.XXBTZUSD (BTC) or result.XETHZUSD (ETH)
#   c[0] = last trade price
#   h[1] = 24h high
#   l[1] = 24h low
#   v[1] = 24h volume
#   P[1] = 24h % change (weighted avg vs open)
#
# OHLC response: result.XXBTZUSD = array of candles
#   Each candle: [time, open, high, low, close, vwap, volume, count]
#   time = unix timestamp
